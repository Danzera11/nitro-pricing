NODE_ENV=production

# VM public access. Replace with the VM IP or internal DNS name.
VM_HOST=SEU_IP_OU_DNS_DA_VM
WEB_PORT=5173
API_PORT=3000
VITE_API_URL=http://SEU_IP_OU_DNS_DA_VM:3000
WEB_ORIGIN=http://SEU_IP_OU_DNS_DA_VM:5173

# Database. Change all values before first deploy.
POSTGRES_DB=powerquote
POSTGRES_USER=powerquote
POSTGRES_PASSWORD=TROQUE_SENHA_FORTE_DO_POSTGRES
DATABASE_URL=postgresql://powerquote:TROQUE_SENHA_FORTE_DO_POSTGRES@postgres:5432/powerquote?schema=public

# Internal local login for the first VM stage.
AUTH_MODE=local
LOCAL_AUTH_SECRET=TROQUE_POR_SEGREDO_LONGO_ALEATORIO
LOCAL_AUTH_TOKEN_TTL=12h
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_EMAIL=admin@nitro.local
LOCAL_ADMIN_PASSWORD=vgbrvx2ddm
LOCAL_ADMIN_NAME=Administrador Nitro
LOCAL_ADMIN_ROLES=admin

# Optional initial editor account. Can also be created in the Users screen.
LOCAL_USER_USERNAME=editor
LOCAL_USER_EMAIL=editor@nitro.local
LOCAL_USER_PASSWORD=TROQUE_SENHA_EDITOR
LOCAL_USER_NAME=Editor Nitro
LOCAL_USER_ROLES=editor

# Future SSO placeholders. Keep disabled until Keycloak is adopted.
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/powerquote
KEYCLOAK_AUDIENCE=powerquote-api

# AI provider. Leave empty for mock/fallback mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Traefik stays disabled in this VM stage.
TRAEFIK_ENABLE=false
POWERQUOTE_WEB_HOST=nitro-pricing.local
POWERQUOTE_API_HOST=api.nitro-pricing.local
