NODE_ENV=development

# Public hosts used by Docker, CORS and optional Traefik labels.
POWERQUOTE_WEB_HOST=powerquote.localhost
POWERQUOTE_API_HOST=api.powerquote.localhost
WEB_PORT=5173
API_PORT=3000

# Database
POSTGRES_DB=powerquote
POSTGRES_USER=powerquote
POSTGRES_PASSWORD=powerquote_dev_password
DATABASE_URL=postgresql://powerquote:powerquote_dev_password@postgres:5432/powerquote?schema=public

# Auth: dev uses a mock user. keycloak validates JWTs against the issuer JWKS.
AUTH_MODE=dev
DEV_USER_ID=dev-tecnico
DEV_USER_EMAIL=tecnico@powerquote.local
DEV_USER_NAME=Tecnico Dev
DEV_USER_ROLES=admin,tecnico,comercial,gestor
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/powerquote
KEYCLOAK_AUDIENCE=powerquote-api

# AI provider. Leave empty for deterministic mock generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend
VITE_API_URL=http://localhost:3000
