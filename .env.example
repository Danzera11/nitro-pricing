NODE_ENV=development

# Public hosts used by Docker, CORS and optional Traefik labels.
POWERQUOTE_WEB_HOST=powerquote.localhost
POWERQUOTE_API_HOST=api.powerquote.localhost
WEB_PORT=5173
API_PORT=3000

# Database
POSTGRES_DB=powerquote
POSTGRES_USER=powerquote
POSTGRES_PASSWORD=powerquote_dev_password
DATABASE_URL=postgresql://powerquote:powerquote_dev_password@postgres:5432/powerquote?schema=public

# Auth modes:
# dev = mock user without login, local = simple internal JWT login, keycloak = future OIDC/JWT validation.
AUTH_MODE=local
DEV_USER_ID=dev-tecnico
DEV_USER_EMAIL=tecnico@powerquote.local
DEV_USER_NAME=Tecnico Dev
DEV_USER_ROLES=admin,tecnico,comercial,gestor

# Local auth for internal VM tests. Change all passwords/secrets before exposing the VM.
LOCAL_AUTH_SECRET=change-this-long-random-secret-before-vm
LOCAL_AUTH_TOKEN_TTL=12h
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_EMAIL=admin@nitro.local
LOCAL_ADMIN_PASSWORD=vgbrvx2ddm
LOCAL_ADMIN_NAME=Administrador Nitro
LOCAL_ADMIN_ROLES=admin
LOCAL_USER_USERNAME=editor
LOCAL_USER_EMAIL=tecnico@nitro.local
LOCAL_USER_PASSWORD=change-user-password
LOCAL_USER_NAME=Técnico Nitro
LOCAL_USER_ROLES=editor

KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/powerquote
KEYCLOAK_AUDIENCE=powerquote-api

# AI provider. Leave empty for deterministic mock generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend
VITE_API_URL=http://localhost:3000
