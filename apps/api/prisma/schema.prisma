generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  editor
  visualizador
  tecnico
  comercial
  gestor
}

enum QuoteStatus {
  DRAFT
  EDITING
  SAVED
  EXPORTED
  AI_GENERATED
  TECH_REVIEW
  APPROVED
  REJECTED
  SENT
}

enum QuoteRequestStatus {
  OPEN
  IN_PROGRESS
  QUOTED
  CANCELLED
}

enum AiLearningStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserExternal {
  id           String     @id @default(cuid())
  externalId   String     @unique
  username     String?    @unique
  email        String     @unique
  name         String
  roles        UserRole[] @default([])
  passwordHash String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  requests     QuoteRequest[]
  auditLogs    AuditLog[]
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  document     String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  requests     QuoteRequest[]
}

model Group {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  services    Service[]
  materials   SuggestedMaterial[]
  kits        MaterialKit[]
}

model Unit {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  example     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id                 String   @id @default(cuid())
  groupId            String
  code               String   @unique
  name               String
  description        String?
  unit               String
  baseLaborPrice     Decimal  @db.Decimal(12, 2)
  defaultDifficulty  Decimal  @default(1.0) @db.Decimal(5, 2)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  group              Group    @relation(fields: [groupId], references: [id])
  quoteItems         QuoteItem[]
  materialKits       MaterialKit[]
}

model SuggestedMaterial {
  id          String   @id @default(cuid())
  groupId     String?
  name        String
  description String?
  unit        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  group       Group?   @relation(fields: [groupId], references: [id])
}

model MaterialKit {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  groupId     String?
  serviceId   String?
  itemsJson   Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  group       Group?   @relation(fields: [groupId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])
}

model Variable {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  type        String
  unit        String?
  description String?
  required    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Rule {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  conditionJson Json
  actionJson    Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QuoteRequest {
  id              String             @id @default(cuid())
  customerId      String
  requestedById   String?
  title           String
  description     String
  status          QuoteRequestStatus @default(OPEN)
  inputVariables  Json               @default("{}")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  customer        Customer           @relation(fields: [customerId], references: [id])
  requestedBy     UserExternal?      @relation(fields: [requestedById], references: [id])
  quote           Quote?
  aiRuns          AiRun[]
}

model Quote {
  id             String       @id @default(cuid())
  requestId      String       @unique
  quoteNumber    String?      @unique
  status         QuoteStatus  @default(DRAFT)
  scopeSummary   String?
  assumptions    String[]     @default([])
  risks          String[]     @default([])
  suggestedMaterials Json      @default("[]")
  confidence     String?
  totalLaborPrice Decimal     @default(0) @db.Decimal(12, 2)
  exportedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  request        QuoteRequest @relation(fields: [requestId], references: [id])
  items          QuoteItem[]
}

model AiPrompt {
  id        String   @id @default(cuid())
  name      String
  content   String
  active    Boolean  @default(false)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiLearning {
  id            String           @id @default(cuid())
  title         String
  content       String
  status        AiLearningStatus @default(PENDING)
  active        Boolean          @default(false)
  source        String           @default("manual")
  sourceQuoteId String?
  evidenceJson  Json             @default("{}")
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model QuoteItem {
  id               String   @id @default(cuid())
  quoteId          String
  groupCode        String
  serviceId        String?
  serviceName      String
  description      String
  quantity         Decimal  @db.Decimal(12, 2)
  unit             String
  difficultyFactor Decimal  @db.Decimal(5, 2)
  unitLaborPrice   Decimal  @db.Decimal(12, 2)
  totalLaborPrice  Decimal  @db.Decimal(12, 2)
  notes            String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  quote            Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  service          Service? @relation(fields: [serviceId], references: [id])
}

model AiRun {
  id                 String       @id @default(cuid())
  quoteRequestId     String
  provider           String
  model              String?
  promptSnapshot     Json
  responseJson       Json
  assumptions        String[]     @default([])
  risks              String[]     @default([])
  confidenceLevel    String
  createdAt          DateTime     @default(now())
  quoteRequest       QuoteRequest @relation(fields: [quoteRequestId], references: [id])
}

model AuditLog {
  id          String        @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  entity      String
  entityId    String?
  action      String
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  createdAt   DateTime      @default(now())
  actor       UserExternal? @relation(fields: [actorUserId], references: [id])
}
